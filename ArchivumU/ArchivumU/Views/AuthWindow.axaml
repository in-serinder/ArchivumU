<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ArchivumU.ViewModels"
        mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="200"
        Width="320" Height="200"
        MaxWidth="320" MaxHeight="200"
        x:Class="ArchivumU.Views.AuthWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding I18n.Authentication}"
        Background="#F8F9FA"
        Icon="/Assets/auth.ico"
        Padding="16">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#4A90D9" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinWidth" Value="70" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="#E9ECEF" />
            <Setter Property="Foreground" Value="#495057" />
        </Style>
        
        <Style Selector="Label">
            <Setter Property="Foreground" Value="#495057" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#DEE2E6" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="90,*" RowSpacing="10">
        <!-- 标题区域 -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" 
                Background="White" 
                CornerRadius="8" 
                Padding="12"
                Margin="0,0,0,6">
            <StackPanel Spacing="2">
                <TextBlock Text="{Binding I18n.Authentication}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#212529" />
                <TextBlock Name="TBAuthOBJ"
                           FontSize="11" 
                           Foreground="#6C757D" />

            </StackPanel>
        </Border>
        
        <!-- 密码标签 -->
        <Label Grid.Row="1" Grid.Column="0" Content="{Binding I18n.Password}" />
        
        <!-- 密码输入框 -->
        <TextBox Grid.Row="1" Grid.Column="1" 
                     x:Name="PasswordInput" />
        
        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    Spacing="8" 
                    HorizontalAlignment="Right">
            <Button Classes="Secondary" Content="{Binding I18n.Cancel}"  Name="BTNAuthWinClose" Click="BTNAuthWinClose_OnClick" />
            <Button Content="{Binding I18n.Config}" />
        </StackPanel>
    </Grid>

</Window>